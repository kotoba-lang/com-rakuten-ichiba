// Rakuten_ichiba clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace rakuten_ichiba {

    entity Product {
        id: string @unique
        sku: string
        title: string
        price: float
        currency: string
        inventory: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Variant {
        id: string @unique
        productId: string
        sku: string
        price: float
        optionValues: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Order {
        id: string @unique
        customerId: string
        number: string
        total: float
        currency: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity LineItem {
        id: string @unique
        orderId: string
        productId: string
        quantity: integer
        unitPrice: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Customer {
        id: string @unique
        email: string
        firstName: string
        lastName: string
        phone: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Collection {
        id: string @unique
        title: string
        handle: string
        published: boolean
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
